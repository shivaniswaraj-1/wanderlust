<% layout("/layouts/boilerplate") -%>

<div class="row mt-5">
  <div class="col-md-6 offset-md-3 col-lg-4 offset-lg-4">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h3 class="card-title fw-bold mb-4 text-center">Welcome back</h3>

        <form action="/login" method="POST" novalidate class="needs-validation">
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" name="username" id="username"
                   class="form-control" placeholder="Your username" required>
            <div class="invalid-feedback">Please enter your username.</div>
          </div>
          <div class="mb-4">
            <label for="password" class="form-label">Password</label>
            <input type="password" name="password" id="password"
                   class="form-control" placeholder="Your password" required>
            <div class="invalid-feedback">Please enter your password.</div>
          </div>
          <button type="submit" class="btn btn-danger w-100">Login</button>
        </form>

        <hr>
        <p class="text-center text-muted small mb-0">
          New to WanderLust? <a href="/signup">Sign Up</a>
        </p>
      </div>
    </div>
  </div>
</div>
