# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from: Atlas Dashboard → Your Cluster → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
# IMPORTANT: URL-encode special chars in password (e.g. @ → %40, # → %23)
ATLASDB_URL=mongodb+srv://username:password@cluster.mongodb.net/wanderlust

# ── Session secret ────────────────────────────────────────────────────────────
# Any long random string (32+ characters recommended)
SECRET=your_super_secret_session_key_here_make_it_long

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
# Get these from: cloudinary.com → Dashboard
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# ── Nodemailer / Gmail (OTP emails) ──────────────────────────────────────────
# VERIFICATION_SENDER_EMAIL : your Gmail address
# VERIFICATION_EMAIL_PASSWORD : Gmail APP PASSWORD (not your login password!)
#   Generate at: Google Account → Security → 2-Step Verification → App Passwords
VERIFICATION_SENDER_EMAIL=your_gmail@gmail.com
VERIFICATION_EMAIL_PASSWORD=your_16_char_app_password

# ── Map / Geocoding ───────────────────────────────────────────────────────────
# MAP_TOKEN is NOT required.
# This project uses Leaflet + OpenStreetMap for maps (completely free).
# Geocoding uses Nominatim API (also free, no key needed).

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
